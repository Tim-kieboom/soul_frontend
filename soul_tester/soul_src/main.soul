extern "C" free(ptr: *none)
extern "C" malloc(len: int): *none
extern "C" __clib_printChar(ch: char)
extern "C" __clib_printStr(text: *char)
extern "C" __clib_fmtInt(value: int, base: u8, buffer: *char/*[50]char*/, capital: bool): *char
extern "C" __clib_fmtUint(value: uint, base: u8, buffer: *char/*[50]char*/, capital: bool): *char
extern "C" __clib_fmtFloat(value: f64, base: u8, buffer: *char/*[50]char*/, precision: u8, capital: bool): *char

global1: int = 1 + 2
global2: int = 3
fmtBuffer := malloc(50) as *char //[for 50 => '\0']

main() {
    // pow := 3 ** 2
    // root := 2 </ 4

    print_int(-123)
    endln()
    print_uint(123)
    endln()
    print_float(123.4567)
    endln()
}

gen<T>(value: T): int {}

endln() {
    __clib_printChar('\n')
}

print_int(value: int, base: u8 = 10, capital: bool = true) {
    cstr := __clib_fmtInt(value, base, fmtBuffer, capital)
    __clib_printStr(cstr)
}

print_uint(value: uint, base: u8 = 10, capital: bool = true) {
    cstr := __clib_fmtUint(value, base, fmtBuffer, capital)
    __clib_printStr(cstr)
}

print_float(value: f64, base: u8 = 10, capital: bool = true, precision: u8 = 4) {
    cstr := __clib_fmtFloat(value, base, fmtBuffer, precision, capital)
    __clib_printStr(cstr)
}

sum(a: int, b: int): int {
    a + b
}

ptr() {
    ptr := malloc(32) as *int
