struct Duration {
    mut sec: u64
    mut nano: u32
}

// extern "C" free(ptr: *none)
extern "C" malloc(len: uint): *none
extern "C" __clib_printChar(ch: char)
extern "C" __clib_printStr(text: *char)

main() {

    len := 23
    print_int(len)

    comptimePow := 3 ** 2
    comptimeRoot := 2 </ 4
    generics()
    prints()
    comptime()

    num := ifs()
    print_int(num)
}

