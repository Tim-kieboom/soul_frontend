struct Duration {
    mut sec: u64
    mut nano: u32
}

extern "C" __clib_printChar(ch: char)
extern "C" __clib_printCStr(text: *char)

Duration Empty(): Duration {
    Duration{sec: 0, nano: 0}
}

Duration Now(): Duration {
    extern "C" __clib_Duration_now(duration: &Duration)

    mut time = Duration.Empty()
    __clib_Duration_now(&time)
    time
}

Duration Print(self: Duration) {
    sec := self.sec
    nano := self.nano
    print("Duration{sec: ")
    print_uint(sec as uint)
    print(", nano: ")
    print_uint(nano as uint)
    print("}")
}

sum(a: int, b: int): int {
    1
}

int sum(a: int, b: int): int {
    a + b
}

int add(this, b: int): int {
    b
}

extern "C" __clib_delay_sec(sec: int)
main() {
    println("hello world")

    now := Duration.Now()
    Duration.Print(now)
    endln()

    len := 23
    println_int(sum(len, 1))
    println_int(int.sum(len, 1))
    println_int(len.add(1))

    comptimePow := 3 ** 2
    comptimeRoot := 2 </ 4
    generics()
    prints()
    comptime()

    num := ifs()
    println_int(num)
}

