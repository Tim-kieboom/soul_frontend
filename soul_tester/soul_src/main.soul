struct Duration {
    mut sec: u64
    mut nano: u32
}

// extern "C" free(ptr: *none)
extern "C" malloc(len: int): *none
extern "C" __clib_printChar(ch: char)
extern "C" __clib_printStr(text: *char)

global := 1
global1 := 10 + 33 * 2
fmtBuffer := malloc(50) as *char //[for 50 => '\0']

Now(): Duration {
    extern "C" __clib_Duration_now(duration: &Duration)
    
    mut start := Duration{sec: 0, nano: 0} 
    ref := &start
    __clib_Duration_now(ref)
    return start
}

