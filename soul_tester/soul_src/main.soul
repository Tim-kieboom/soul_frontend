endln() {
    __clib_printChar('\n')
}

print_char(char: char) {
    __clib_printChar(char)
}

print_int(value: int, base: u8 = 10, capital: bool = true) {
    
    extern "C" __clib_fmtInt(
        value: int, 
        base: u8, 
        buffer: *char/*[50]char*/, 
        capital: bool,
    ): *char
    
    cstr := __clib_fmtInt(value, base, fmtBuffer, capital)
    __clib_printStr(cstr)
}

print_uint(value: uint, base: u8 = 10, capital: bool = true) {
    
    extern "C" __clib_fmtUint(
        value: uint, 
        base: u8, 
        buffer: *char/*[50]char*/, 
        capital: bool,
    ): *char
    
    cstr := __clib_fmtUint(value, base, fmtBuffer, capital)
    __clib_printStr(cstr)
}

print_float(value: f64, base: u8 = 10, capital: bool = true, precision: u8 = 4) {
    
    extern "C" __clib_fmtFloat(
        value: f64, 
        base: u8, 
        buffer: *char/*[50]char*/, 
        precision: u8, 
        capital: bool,
    ): *char

    cstr := __clib_fmtFloat(value, base, fmtBuffer, precision, capital)
    __clib_printStr(cstr)
}

