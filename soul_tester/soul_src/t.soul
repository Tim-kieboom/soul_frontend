struct Duration {
    mut sec: u64
    mut nano: u32
}

extern "C" __clib_printChar(ch: char)
extern "C" __clib_printCStr(text: *char)

trait Formatter {
    Push(&this, ch: char)
    PushStr(&this, text: [@]char)
}

class StringBuilder {
    sb: List<char>
    This() {
        This{sb: List()}
    }

    impl Formatter {
        Push(&this, ch: char) {
            sb.Push(ch)
        }

        PushStr(&this, text: [@]char) {
            for ch in text {
                sb.Push(ch)
            }
        }
    }

    AsStr(this): [@]char {
        this.sb.AsSlice()
    }
}

trait Display<Fmt: Formatter> {
    Display(&this, fmt: &Fmt)
}

use<Fmt: Formatter> int impl Display<Fmt> {
    Display(@this, fmt: &Fmt) {
        literal NUMBERS = "0123456789"
        literal BASE = uint(10)
        mut buffer: [50]char
        mut i = buffer.len

        sign := *this < 0
        number := if sign {
            uint(-*this)
        } else {
            uint(*this)
        }

        while {
            buffer[--i] = NUMBERS[number % BASE]
            number /= BASE
            if number <= 0 {
                break
            }
        }

        buffer[--i] = '-'
        fmt.PushStr(@buffer[i..])
    }
}

