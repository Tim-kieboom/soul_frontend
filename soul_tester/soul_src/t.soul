use Duration {
    Empty(): Duration {
        Duration{sec: 0, nano: 0}
    }

    Now(): Duration {
        extern "C" __clib_Duration_now(duration: &Duration)

        mut time = Duration.Empty()
        __clib_Duration_now(&time)
        time
    }

    Print(@this) {
        sec := this.sec
        nano := this.nano
        print("Duration{sec: ")
        print_uint(sec as uint)
        print(", nano: ")
        print_uint(nano as uint)
        print("}")
    }
}

const sum(a: int, b: int): int {
    1
}

int sum(a: int, b: int): int {
    a + b
}

int add(this, b: int): int {
    this + b
}

int addMut(&this, b: int): int {
    a := *this
    a + b
}

int addRef(@this, b: int): int {
    a := *this
    a + b
}

main() {
    println("hello world")

    now := Duration.Now()
    now.Print()
    endln()

    mut len := 23
    println_int(sum(len, 1))
    println_int(int.sum(len, 1))
    println_int(len.add(1))
    println_int(len.addRef(1))
    println_int(len.addMut(1))

    comptimePow := 3 ** 2
    comptimeRoot := 2 </ 4
    generics()
    prints()
    comptime()

    num := ifs()
    println_int(num)
    // whiles()
}

