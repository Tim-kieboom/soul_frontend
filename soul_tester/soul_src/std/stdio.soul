extern "C" __csoul_printChar(ch: char)

#[public]
print(value: impl Fmt) {
    mut fmt = StringBuilder()
    value.Fmt(&fmt)
    for ch in fmt {
        __csoul_printChar(ch)
    }
}

#[public]
println(value: impl Fmt) {
    print(value)
    __csoul_printChar('\n')
}

#[public]
panic(text: impl Fmt) {
    print(text)
    exit(1)
}

