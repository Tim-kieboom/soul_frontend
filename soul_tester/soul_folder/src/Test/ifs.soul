import (
    ./.Io
)

RunTests() {
    test_ReturnIf_should_return_1()
    // test_ReturnIfElse_should_return_5()
    // test_ReturnIfElseIf_should_return_3()
    test_NestedIf_should_return_10()
    test_IfWithoutElse_should_return_0()
    test_Elif_should_assign_3()
    test_Ternary_should_return_2()
    test_BigIfs_should_return_10()
}

test_ReturnIf_should_return_1() {
    returnIf(): int {
        if false {
            num := 1
            return num
        }
        0
    }

    value := returnIf()
    Io.PrintAssert(value == 0, "|'test_ReturnIf_elsereturns_0()' FAILED file: Test/ifs.soul| value should be 0")
}

