test_NestedIf_should_return_10() {
    nestedIf(): int {
        if true {
            if true {
                return 10
            }
            return 5
        }
        0
    }

    value := nestedIf()
    Io.PrintAssert(value == 10, "|'test_NestedIf_should_return_10()' FAILED file: Test/ifs.soul| value should be 10")
}

test_IfWithoutElse_should_return_0() {
    ifWithoutElse(): int {
        if false {
            num := 1
        }
        0
    }

    value := ifWithoutElse()
    Io.PrintAssert(value == 0, "|'test_IfWithoutElse_should_return_0()' FAILED file: Test/ifs.soul| value should be 0")
}

test_BigIfs_should_return_10() {
    value := if 1==3 {
        6
    } else if 1==4 {
        7
    } else if 1==5 {
        8
    } else if 1==6 {
        9
    } else {
        10
    }

    if value != 10 {
        Io.Print_int(value)
    }
    Io.PrintAssert(value == 10, "|'test_BigIfs_should_return_10()' FAILED file: Test/ifs.soul| value should be 10")
}

test_Ternary_should_return_2() {

    value := if 1==0 {
        1
    } else {
        2
    }

    if value != 2 {
        Io.Print_int(value)
    }
    Io.PrintAssert(value == 2, "|'test_Ternary_should_return_2()' FAILED file: Test/ifs.soul| value should be 2")
}

test_Elif_should_assign_3() {

    mut value = 0
    if 1==1 {
        value = 3
    } else if 1==2 {
        value = 4
    } else {
        value = 5
    }

    Io.PrintAssert(value == 3, "|'test_Elif_should_assign_3()' FAILED file: Test/ifs.soul| value should be 3")
}